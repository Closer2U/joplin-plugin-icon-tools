{
  "name": "joplin-plugin-auto-icon-assigner",
  "version": "0.1.8",
  "description": "Automatically assign per-level custom icons to Joplin notebooks and sub-notebooks.",
  "main": "dist/index.js",
  "keywords": [
    "joplin",
    "joplin-plugin",
    "notebook",
    "folder",
    "icon"
  ],
  "scripts": {
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true});require('fs').rmSync('publish',{recursive:true,force:true});\"",
    "build": "webpack --mode=production",
    "dist": "npm run clean && npm run build && node build/package-jpl.js",
    "dev": "webpack --mode=development --watch"
  },
  "devDependencies": {
    "@types/node": "^20.12.12",
    "adm-zip": "^0.5.16",
    "copy-webpack-plugin": "^12.0.2",
    "tar": "^7.5.15",
    "ts-loader": "^9.5.1",
    "typescript": "^5.5.4",
    "webpack": "^5.91.0",
    "webpack-cli": "^5.1.4"
  },
  "license": "MIT",
  "private": true
}
